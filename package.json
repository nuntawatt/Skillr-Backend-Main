{
  "name": "skillr",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "packageManager": "pnpm@10.26.1+sha512.664074abc367d2c9324fdc18037097ce0a8f126034160f709928e9e9f95d98714347044e5c3164d65bd5da6c59c6be362b107546292a8eecb7999196e5ce58fa",
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build course",
    "build:all": "nest build",
    "build:auth": "nest build auth-service",
    "build:course": "nest build course-service",
    "build:reward": "nest build reward-service",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\" \"test/**/*.ts\"",
    "start": "cross-env PORT=3001 nest start course",
    "start:dev": "cross-env PORT=3001 nest start course --watch",
    "start:debug": "cross-env PORT=3001 nest start course --debug --watch",
    "start:prod": "cross-env PORT=3002 node dist/apps/course/src/main.js",
    "start:auth": "cross-env PORT=3001 nest start auth --watch",
    "start:course": "cross-env PORT=3002 nest start course --watch",
    "start:reward": "cross-env PORT=3003 nest start reward --watch",
    "typeorm:course": "node --require ts-node/register -r tsconfig-paths/register ./node_modules/typeorm/cli.js -d apps/course-service/data-source.ts",
    "typeorm:auth": "node --require ts-node/register -r tsconfig-paths/register ./node_modules/typeorm/cli.js -d apps/auth-service/data-source.ts",
    "typeorm:reward": "node --require ts-node/register -r tsconfig-paths/register ./node_modules/typeorm/cli.js -d apps/reward-service/data-source.ts",
    "migration:run:auth": "pnpm typeorm:auth migration:run",
    "migration:run:course": "pnpm typeorm:course migration:run",
    "migration:run:reward": "pnpm typeorm:reward migration:run",
    "migration:generate:auth": "pnpm typeorm:auth migration:generate apps/auth-service/migrations/$MIGRATION_NAME",
    "migration:generate:course": "pnpm typeorm:course migration:generate apps/course-service/migrations/$MIGRATION_NAME",
    "migration:generate:reward": "pnpm typeorm:reward migration:generate apps/reward-service/migrations/$MIGRATION_NAME",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@aws-sdk/client-mediaconvert": "^3.971.0",
    "@aws-sdk/client-s3": "^3.957.0",
    "@aws-sdk/s3-request-presigner": "^3.957.0",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@nestjs-modules/mailer": "^1.11.2",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.14",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.3",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.1.14",
    "@types/cookie-parser": "^1.4.10",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/uuid": "^10.0.0",
    "argon2": "^0.44.0",
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "cookie-parser": "^1.4.7",
    "file-type": "^21.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "form-data": "^4.0.5",
    "fs-extra": "^11.2.0",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "mime-types": "^2.1.35",
    "ms": "^2.1.3",
    "multer": "^2.0.2",
    "nodemailer": "^6.9.16",
    "openai": "^6.25.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.7.0",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.28",
    "typeorm-ts-node-commonjs": "^0.3.20",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@epic-web/invariant": "^1.0.0",
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^30.0.0",
    "@types/mime-types": "^2.1.4",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "roots": [
      "<rootDir>/apps/auth-service/src",
      "<rootDir>/apps/course-service/src",
      "<rootDir>/apps/reward-service/src",
      "<rootDir>/test"
    ],
    "moduleNameMapper": {
      "^apps/(.*)$": "<rootDir>/apps/$1",
      "^@common/(.*)$": "<rootDir>/libs/common/src/$1",
      "^@config/(.*)$": "<rootDir>/libs/config/src/$1",
      "^@shared/(.*)$": "<rootDir>/libs/shared/src/$1",
      "^@auth$": "<rootDir>/libs/auth/src",
      "^@auth/(.*)$": "<rootDir>/libs/auth/src/$1"
    },
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(uuid|@nestjs/axios|axios))"
    ],
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node"
  }
}