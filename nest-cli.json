{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "monorepo": true,
  "root": "apps/auth-service",
  "sourceRoot": "apps/auth-service/src",
  "compilerOptions": {
    "deleteOutDir": false
  },
  "projects": {
    "auth": {
      "type": "application",
      "root": "apps/auth-service",
      "entryFile": "main",
      "sourceRoot": "apps/auth-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/auth-service/tsconfig.app.json"
      }
    },
    "course": {
      "type": "application",
      "root": "apps/course-service",
      "entryFile": "main",
      "sourceRoot": "apps/course-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/course-service/tsconfig.app.json"
      }
    },
    "reward": {
      "type": "application",
      "root": "apps/reward-service",
      "entryFile": "main",
      "sourceRoot": "apps/reward-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/reward-service/tsconfig.app.json"
      }
    },
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src"
    },
    "config": {
      "type": "library",
      "root": "libs/config",
      "entryFile": "index",
      "sourceRoot": "libs/config/src"
    },
    "shared": {
      "type": "library",
      "root": "libs/shared",
      "entryFile": "index",
      "sourceRoot": "libs/shared/src"
    },
    "auth-lib": {
      "type": "library",
      "root": "libs/auth",
      "entryFile": "index",
      "sourceRoot": "libs/auth/src"
    },
    "stock": {
      "type": "application",
      "root": "apps/stock",
      "entryFile": "main",
      "sourceRoot": "apps/stock/src",
      "compilerOptions": {
        "tsConfigPath": "apps/stock/tsconfig.app.json"
      }
    }
  }
}